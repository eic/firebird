# MANIFEST.in

# pyrobird library
recursive-include pyrobird *.py

# Include YAML files
include pyrobird/data/*.yaml

# Include all files in the static and templates directories
recursive-include pyrobird/server/static *
# Exclude unzipped .firebird data dirs (redundant with .zip versions; paths exceed Windows MAX_PATH)
recursive-exclude pyrobird/server/static/assets/data *.firebird.json
recursive-include pyrobird/server/templates *
